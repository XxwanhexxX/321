local autoTasks = {}

local function getBoostValue(folderName)
    local player = game.Players.LocalPlayer
    local boostFolder = player:FindFirstChild("boostTimersFolder")
    if boostFolder then
        local target = boostFolder:FindFirstChild(folderName)
        if target then
            local val = target:FindFirstChild("Value")
            if val then
                return val.Value
            end
        end
    end
    return nil
end

local function autoUseItem(itemName, folderName, stateKey, cooldown)
    cooldown = cooldown or 1
    
    if autoTasks[stateKey] then
        task.cancel(autoTasks[stateKey])
        autoTasks[stateKey] = nil
    end
    
    getgenv()[stateKey] = state
    
    if state then
        autoTasks[stateKey] = task.spawn(function()
            while getgenv()[stateKey] do
                local player = game.Players.LocalPlayer
                local char = player.Character
                if char then
                    local humanoid = char:FindFirstChild("Humanoid")
                    if humanoid then
                        local boostVal = getBoostValue(folderName)
                        
                        if boostVal == -1 or boostVal == 0 or boostVal == nil then
                            local used = false
                            for _, v in pairs(player.Backpack:GetChildren()) do
                                if v:IsA("Tool") and v.Name:find(itemName) then
                                    humanoid:EquipTool(v)
                                    task.wait(0.2)
                                    v:Activate()
                                    used = true
                                    task.wait(cooldown)
                                    break
                                end
                            end
                            if not used then
                                for _, v in pairs(char:GetChildren()) do
                                    if v:IsA("Tool") and v.Name:find(itemName) then
                                        v:Activate()
                                        used = true
                                        task.wait(cooldown)
                                        break
                                    end
                                end
                            end
                        end
                    end
                end
                task.wait(0.5)
            end
        end)
    end
end

