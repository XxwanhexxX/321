local sendSection = B:Section({Title = "送蛋", Opened = true})
local targetPlayer = ""
local sendNum = 0
local eggParagraph = nil
local isSending = false

local function getEggCount()
    local count = 0
    local player = game:GetService("Players").LocalPlayer
    local folder = player:FindFirstChild("consumablesFolder")
    if folder then
        for _, item in pairs(folder:GetChildren()) do
            if item.Name == "Protein Egg" then
                count = count + 1
            end
        end
    end
    return count
end

local function updateEggDisplay()
    if eggParagraph then
        eggParagraph:SetDesc(tostring(getEggCount()) .. " 个")
    end
end

eggParagraph = sendSection:Paragraph({
    Title = "剩余蛋数量",
    Desc = tostring(getEggCount()) .. " 个",
})

sendSection:Input({
    Title = "送蛋数量",
    Desc = "输入送蛋数量",
    Callback = function(value)
        sendNum = tonumber(value) or 0
    end
})

sendSection:Input({
    Title = "用户名",
    Desc = "输入对面用户名",
    Live = true,
    Callback = function(value)
        targetPlayer = value
    end
})

local function sendEgg()
    if not targetPlayer or targetPlayer == "" then return false end
    if sendNum <= 0 then return false end
    if getEggCount() <= 0 then return false end
    
    local target = game:GetService("Players"):FindFirstChild(targetPlayer)
    if not target then return false end
    
    local player = game:GetService("Players").LocalPlayer
    local folder = player:FindFirstChild("consumablesFolder")
    if not folder then return false end
    
    local egg = nil
    for _, item in pairs(folder:GetChildren()) do
        if item.Name == "Protein Egg" then
            egg = item
            break
        end
    end
    if not egg then return false end
    
    local args = {"giftRequest", target, egg}
    game:GetService("ReplicatedStorage"):WaitForChild("rEvents"):WaitForChild("giftRemote"):InvokeServer(unpack(args))
    updateEggDisplay()
    return true
end

sendSection:Button({
    Title = "开始送蛋",
    Callback = function()
        if isSending then return end
        
        if not targetPlayer or targetPlayer == "" then
            return
        end
        
        local target = game:GetService("Players"):FindFirstChild(targetPlayer)
        if not target then
            return
        end
        
        if sendNum <= 0 then
            return
        end
        
        if getEggCount() <= 0 then
            return
        end
        
        isSending = true
        task.spawn(function()
            local sent = 0
            for i = 1, sendNum do
                if getEggCount() <= 0 then break end
                if not game:GetService("Players"):FindFirstChild(targetPlayer) then break end
                if sendEgg() then
                    sent = sent + 1
                else
                    break
                end
                task.wait(0.1)
            end
            isSending = false
        end)
    end
})

task.spawn(function()
    while true do
        task.wait(0.1)
        if eggParagraph then
            updateEggDisplay()
        end
    end
end)

