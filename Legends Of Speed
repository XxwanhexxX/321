                Url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?limit=100&excludeFullGames=true",
                Method = "GET"
            })
            return HttpService:JSONDecode(response.Body)
        end)
        
        if success and result and result.data and #result.data > 0 then
            local target = result.data[math.random(1, #result.data)]
